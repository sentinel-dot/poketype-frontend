# Pokétype Frontend — Umgebungsvariablen
# Diese Datei nach .env.local kopieren und Werte eintragen.

# Backend-URL (Pflicht)
NEXT_PUBLIC_API_URL=http://localhost:4000

# LiveKit wird auf dem BACKEND konfiguriert, nicht hier.
# Benötigte Backend-Variablen (siehe backend_changes.md):
#   LIVEKIT_API_KEY=dein_api_key
#   LIVEKIT_API_SECRET=dein_api_secret
#   LIVEKIT_URL=wss://deine-livekit-instanz.livekit.cloud
#
# Ohne diese Backend-Variablen startet der Server trotzdem.
# Kamera/Stream-Buttons sind dann deaktiviert (503-Fallback auf Placeholder).
